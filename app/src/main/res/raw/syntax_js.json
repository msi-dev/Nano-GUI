{
  "extension": "js",
  "keyword_pattern": "\\b(const|let|var|function|class|if|else|for|while|do|switch|case|default|break|continue|return|try|catch|finally|throw|import|export|from|as|new|this|super|static|async|await|yield|null|undefined|true|false|typeof|instanceof|in|of)\\b",
  "comment_pattern": "//.*|/\\*[^*]*\\*+(?:[^/*][^*]*\\*+)*/",
  "string_pattern": "\"[^\"]*\"|'[^']*'",
  "default_colors": {
    "keyword": "#FFFF55",
    "string": "#00DD00",
    "comment": "#808080"
  }
}
